# Database — PostgreSQL (Render, Neon, or local docker compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creator_platform"

# Public URL (metadata, sitemap, OG). Set to your domain in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required — use: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-long-random-string"

# Payments — mock settles instantly in dev
PAYMENTS_MODE="mock"
MOCK_PAYMENT_AUTO_SUCCEED="true"

# Adult processor (production — CCBill / Segpay)
# PAYMENT_PROCESSOR_API_KEY=
# PAYMENT_PROCESSOR_WEBHOOK_SECRET=

# Age verification — automated (mock_auto when unset)
# VERIFF_API_KEY=
# VERIFF_API_SECRET=
# VERIFF_API_URL=https://stationapi.veriff.com
# YOTI_SDK_ID=
# YOTI_WEBHOOK_SECRET=

# LiveKit — optional; without these, live shows use preview UI
# LIVEKIT_URL="wss://your-project.livekit.cloud"
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# Uploads (future — R2/S3)
# UPLOAD_DRIVER=local
# UPLOAD_LOCAL_DIR=.uploads

# Feature flags
ENABLE_CREATOR_PRO="true"
ENABLE_FAN_PLATFORM_PLUS="true"

# PostgreSQL local (optional): docker compose up -d
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creator_platform"
